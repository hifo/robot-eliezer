{
  "name": "robot-eliezer",
  "version": "1.0.0",
  "description": "A Discord bot named Robot Eliezer",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "mocha",
    "test:report": "mocha --reporter mochawesome --reporter-options reportDir=reports/mochawesome,reportFilename=index,quiet=true,html=true,json=true",
    "coverage": "c8 --reporter=text --reporter=html --reporter=lcov mocha"
  },
  "keywords": ["discord", "bot"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.1",
    "@hebcal/core": "^6.0.8"
  },
  "devDependencies": {
    "mocha": "^10.0.0",
    "chai": "^4.3.0",
    "mochawesome": "^7.1.3",
    "c8": "^10.1.3"
  }
}
